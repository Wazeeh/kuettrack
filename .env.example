# VeloTrack Configuration Template

# =====================================================
# Backend Configuration (.env)
# =====================================================

# MongoDB Atlas Connection
# Get connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.mongodb.net/velotrack?retryWrites=true&w=majority

# JWT Secret (use a strong random string)
# Generate: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_to_something_very_secure_and_random_12345

# Admin Account (created on first run)
ADMIN_EMAIL=admin@velotrack.com
ADMIN_PASSWORD=Admin@1234

# Setup Secret (for initial admin creation)
SETUP_SECRET=your_setup_secret_key_for_bootstrap

# Server Port
PORT=5000

# =====================================================
# ESP-32 Configuration (esp32_rfid_controller.ino)
# =====================================================

# WiFi Settings
WIFI_SSID=Your_WiFi_Network_Name
WIFI_PASSWORD=Your_WiFi_Password

# API Configuration
API_BASE_URL=http://192.168.1.100:5000

# Hardware IDs
BIKE_ID=BIKE-001
STATION_ID=STATION-001

# =====================================================
# Pin Configuration (ESP-32)
# =====================================================

# RFID Reader (RC522)
RST_PIN=GPIO 22
SS_PIN=GPIO 21

# Status LEDs
GREEN_LED=GPIO 32
RED_LED=GPIO 33

# Audio Feedback
BUZZER_PIN=GPIO 25

# LCD Display
LCD_ADDR=0x27  # I2C Address
LCD_COLS=16
LCD_ROWS=2

# =====================================================
# Database Indexes (MongoDB)
# =====================================================

# Create these indexes in MongoDB for better performance:

# Users collection
db.users.createIndex({ "email": 1 }, { "unique": true })
db.users.createIndex({ "rfidUid": 1 })

# RFID Logins collection
db.rfidlogins.createIndex({ "timestamp": -1 })
db.rfidlogins.createIndex({ "userId": 1 })
db.rfidlogins.createIndex({ "rfidUid": 1 })

# Rides collection
db.rides.createIndex({ "userId": 1 })
db.rides.createIndex({ "startTime": -1 })

# =====================================================
# Frontend Configuration
# =====================================================

# Update these URLs in HTML files if using separate servers:

# In all HTML files, update:
const API_BASE_URL = "http://localhost:5000"

# If using different domain:
const API_BASE_URL = "http://your-domain.com:5000"

# =====================================================
# Safety Checklist
# =====================================================

PRE_DEPLOYMENT:
- [ ] Change ADMIN_PASSWORD in production
- [ ] Use strong JWT_SECRET (32+ characters)
- [ ] Whitelist IP in MongoDB Atlas
- [ ] Enable SSL/HTTPS
- [ ] Set NODE_ENV=production
- [ ] Configure CORS properly
- [ ] Set up rate limiting
- [ ] Enable database backups
- [ ] Test RFID reader hardware
- [ ] Verify WiFi connection on ESP-32
- [ ] Test all API endpoints
- [ ] Verify frontend can reach backend
- [ ] Test admin dashboard access
- [ ] Review security settings
- [ ] Set up error logging

# =====================================================
# Common Issues & Solutions
# =====================================================

ESP-32 Won't Connect to WiFi:
  - Verify WIFI_SSID and WIFI_PASSWORD
  - Check if router is 2.4GHz (5GHz not supported)
  - Ensure ESP-32 antenna is properly soldered
  - Try using Wi-Fi QR code scanner

Backend Connection Failed:
  - Check MongoDB URI is correct
  - Whitelist your IP in MongoDB Atlas IP Access List
  - Ensure cluster is active (not paused)
  - Verify network allows MongoDB port 27017

RFID Reader Not Working:
  - Check wiring (especially RST and SS pins)
  - Verify SPI pins match code (MOSI=23, MISO=19, SCK=18)
  - Test with different RFID cards
  - Check 3.3V power supply voltage

Admin Dashboard Not Loading:
  - Verify admin credentials are correct
  - Check browser console for errors (F12)
  - Ensure backend is running
  - Clear browser cache and retry
  - Try different browser

# =====================================================
# Development vs Production
# =====================================================

DEVELOPMENT:
- NODE_ENV=development
- MONGODB_URI=local or test Atlas cluster
- JWT expires in 7 days
- CORS: * (allow all)
- Debug logging enabled

PRODUCTION:
- NODE_ENV=production
- MONGODB_URI=production Atlas cluster
- JWT expires in 7 days (or less)
- CORS: specific domains only
- Rate limiting enabled
- HTTPS required
- Database backups enabled
- Error logging to external service

# =====================================================
# Hardware Bill of Materials (BOM)
# =====================================================

Quantity | Item | Est. Cost | Notes
1x | ESP-32 Dev Board | $8 | From AliExpress/Amazon
1x | RC522 RFID Module | $6 | 13.56MHz reader
1x | 16x2 LCD 1602 I2C | $4 | With backlight
2x | LED (Green & Red) | $0.50 | 5mm standard
1x | 5V Buzzer | $2 | Passive/Active
1x | USB 5V Power | $5 | Adapter
- | Jumper Wires | $2 | Pack of 40
- | Breadboard | $3 | Optional
- | Resistors | $1 | 330Ω for LEDs
- | Wiring | Minimal | Included with setup

TOTAL: ~$31-40 per kiosk

# =====================================================
# Testing Commands
# =====================================================

# Start backend with debug logging
NODE_ENV=development node server.js

# Test RFID endpoint
curl http://localhost:5000/api/auth/user-by-rfid/TEST123

# Get admin stats
curl -H "Authorization: Bearer YOUR_TOKEN" \
     http://localhost:5000/api/admin/rfid-stats

# Create test user
curl -X POST http://localhost:5000/api/auth/register \
  -H "Content-Type: application/json" \
  -d '{"firstName":"Test","lastName":"User","email":"test@example.com",...}'

# =====================================================
# Notes
# =====================================================

- ALWAYS change default admin password after first login
- NEVER commit real credentials to version control
- Use .env file (add to .gitignore)
- Keep private keys secure
- Regular database backups recommended
- Monitor API logs for suspicious activity
- Update dependencies regularly
- Test new deployments in staging first

